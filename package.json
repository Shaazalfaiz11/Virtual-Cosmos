{
  "name": "virtual-cosmos",
  "version": "1.0.0",
  "description": "2D virtual space with proximity-based chat",
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && node index.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "install:all": "cd client && npm install && cd ../server && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
